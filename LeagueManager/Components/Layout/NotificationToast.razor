@inject NotificationService Notifications
@inject ILogger<NotificationToast> Logger
@using LeagueManager.ViewModel
@using Shared.Notifications
@implements IDisposable

<div class="ntoast-container">
    @foreach (var n in _notifications)
    {
        <div class="ntoast ntoast--@n.Message.Level.ToString().ToLower() @(n.Exiting ? "ntoast--exit" : "ntoast--enter")"
             @key="n.Id">
            <div class="ntoast__bar"></div>
            <div class="ntoast__body">
                <div class="ntoast__header">
                    <span class="ntoast__icon">@Icon(n.Message.Level)</span>
                    <span class="ntoast__title">@n.Message.Title</span>
                    <button class="ntoast__close" @onclick="() => Remove(n)">✕</button>
                </div>
                @if (!string.IsNullOrEmpty(n.Message.Detail))
                {
                    <div class="ntoast__detail">@n.Message.Detail</div>
                }
                <div
                    class="ntoast__meta">@n.Message.Source · @n.Message.Timestamp.ToLocalTime().ToString("HH:mm:ss")</div>
            </div>
        </div>
    }
</div>

<style>
    .ntoast-container {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        display: flex;
        flex-direction: column-reverse;
        gap: 0.625rem;
        z-index: 9999;
        pointer-events: none;
    }

    .ntoast {
        display: flex;
        width: 22rem;
        border-radius: 6px;
        overflow: hidden;
        background: #1e1e2e;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
        pointer-events: all;
        font-family: 'Consolas', 'Fira Mono', monospace;
        font-size: 0.8rem;
    }

    .ntoast__bar {
        width: 4px;
        flex-shrink: 0;
    }

    .ntoast__body {
        flex: 1;
        padding: 0.65rem 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        min-width: 0;
    }

    .ntoast__header {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .ntoast__icon {
        font-size: 0.85rem;
    }

    .ntoast__title {
        font-weight: 600;
        flex: 1;
        color: #e2e8f0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ntoast__close {
        background: none;
        border: none;
        color: #64748b;
        cursor: pointer;
        padding: 0 0.2rem;
        font-size: 0.7rem;
        line-height: 1;
        flex-shrink: 0;
    }

    .ntoast__close:hover {
        color: #e2e8f0;
    }

    .ntoast__detail {
        color: #94a3b8;
        line-height: 1.4;
        word-break: break-word;
    }

    .ntoast__meta {
        color: #475569;
        font-size: 0.7rem;
        margin-top: 0.1rem;
    }

    .ntoast--success .ntoast__bar {
        background: #22c55e;
    }

    .ntoast--error .ntoast__bar {
        background: #ef4444;
    }

    .ntoast--warning .ntoast__bar {
        background: #f59e0b;
    }

    .ntoast--info .ntoast__bar {
        background: #3b82f6;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(120%);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes slideOut {
        from {
            opacity: 1;
            transform: translateX(0);
        }
        to {
            opacity: 0;
            transform: translateX(120%);
        }
    }

    .ntoast--enter {
        animation: slideIn 0.22s ease forwards;
    }

    .ntoast--exit {
        animation: slideOut 0.22s ease forwards;
    }
</style>

@code {
    private readonly List<ToastEntry> _notifications = [];
    private const int AutoDismissMs = 5000;
    private bool _disposed;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Logger.LogInformation("NotificationToast subscribed (instance {Id})", GetHashCode());
            Notifications.OnNotification += HandleNotification;
        }
    }

    private void HandleNotification(NotificationMessage msg)
    {
        if (_disposed) return;

        _ = InvokeAsync(async () =>
        {
            try
            {
                var entry = new ToastEntry(msg);
                _notifications.Add(entry);
                StateHasChanged();
                await Task.Delay(AutoDismissMs);
                if (!_disposed) await DismissAsync(entry);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "NotificationToast render error");
            }
        });
    }

    private async Task DismissAsync(ToastEntry entry)
    {
        if (_disposed || !_notifications.Contains(entry)) return;
        entry.Exiting = true;
        StateHasChanged();
        await Task.Delay(220);
        _notifications.Remove(entry);
        StateHasChanged();
    }

    private void Remove(ToastEntry entry)
    {
        _ = InvokeAsync(() => DismissAsync(entry));
    }

    private static string Icon(NotificationLevel level)
    {
        return level switch
        {
            NotificationLevel.Success => "✓",
            NotificationLevel.Error => "✕",
            NotificationLevel.Warning => "⚠",
            _ => "ℹ"
        };
    }

    public void Dispose()
    {
        Logger.LogInformation("NotificationToast disposed (instance {Id})", GetHashCode());
        _disposed = true;
        Notifications.OnNotification -= HandleNotification;
    }

}
