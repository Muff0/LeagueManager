@*
    NOTE on confidence: the HxGrid / HxCheckbox shape below matches the common Havit.Blazor
    pattern (Columns -> HxGridColumn -> ItemTemplate, Data="..." for static binding).
    The HxModal API (Title param, ShowAsync/HideAsync, BodyTemplate/FooterTemplate) and the
    GetDisplayName() extension namespace are less certain on my end - if either fails to
    compile, check IntelliSense / the installed Havit.Blazor version rather than trusting
    this verbatim.
*@
@page "/matches"
@using LeagueManager.Services
@using LeagueManager.ViewModel
@using Shared.Enum
@inject MatchesService MatchesService

<PageTitle>Unplayed Matches</PageTitle>

<h3>Unplayed Matches</h3>
<div class="d-flex align-items-center gap-2 mb-3">
    <label for="round-select" class="form-label mb-0">Round:</label>
    <select id="round-select" class="form-select w-auto"
            @bind="_selectedRound" @bind:after="Refresh">
        @if (_availableRounds != null)
        {
            @foreach (var round in _availableRounds)
            {
                <option value="@round">@round</option>
            }
        }
    </select>
</div>


<HxGrid @ref="_missedMatchesGrid" TItem="UnplayedMatchViewModel" DataProvider="GetUnplayedMatchesData">
        <Columns>
            <HxGridColumn TItem="UnplayedMatchViewModel" HeaderText="Player 1">
                <ItemTemplate>
                    @context.Player1.FirstName (@context.Player1.Rank.GetDisplayName())
                </ItemTemplate>
            </HxGridColumn>

            <HxGridColumn TItem="UnplayedMatchViewModel" HeaderText="Forfeit" ItemCssClass="text-center">
                <ItemTemplate>
                    <HxCheckbox @bind-Value="context.Player1Forfeit" />
                </ItemTemplate>
            </HxGridColumn>

            <HxGridColumn TItem="UnplayedMatchViewModel" HeaderText="Player 2">
                <ItemTemplate>
                    @context.Player2.FirstName (@context.Player2.Rank.GetDisplayName())
                </ItemTemplate>
            </HxGridColumn>

            <HxGridColumn TItem="UnplayedMatchViewModel" HeaderText="Forfeit" ItemCssClass="text-center">
                <ItemTemplate>
                    <HxCheckbox @bind-Value="context.Player2Forfeit" />
                </ItemTemplate>
            </HxGridColumn>

            <HxGridColumn TItem="UnplayedMatchViewModel" HeaderText="">
                <ItemTemplate>
                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            @onclick="() => ShowDetailAsync(context)">
                        Details
                    </button>
                </ItemTemplate>
            </HxGridColumn>
        </Columns>
    </HxGrid>

    <button type="button" class="btn btn-danger mt-3"
            disabled="@(_unplayedMatches != null && !_unplayedMatches.Any(m => m.HasAnyForfeit))"
            @onclick="ProcessForfeitsAsync">
        Process Forfeits
    </button>


<HxModal @ref="_detailModal" Title="Match Details">
    <BodyTemplate>
        @if (_selectedMatch is not null)
        {
            <h6>Player 1</h6>
            <p class="mb-3">
                OGS: @(_selectedMatch.Player1.OgsUsername ?? "—")<br />
                Discord: @(_selectedMatch.Player1.DiscordHandle ?? "—")<br />
                Confirmed time: @(_selectedMatch.Player1.HasConfirmedTime ? "Yes" : "No")
            </p>

            <h6>Player 2</h6>
            <p class="mb-3">
                OGS: @(_selectedMatch.Player2.OgsUsername ?? "—")<br />
                Discord: @(_selectedMatch.Player2.DiscordHandle ?? "—")<br />
                Confirmed time: @(_selectedMatch.Player2.HasConfirmedTime ? "Yes" : "No")
            </p>

            <h6>Scheduled time</h6>
            <p>@(_selectedMatch.ScheduledTime?.ToString("g") ?? "Not scheduled")</p>
        }
    </BodyTemplate>
    <FooterTemplate>
        <button type="button" class="btn btn-secondary" @onclick="() => _detailModal!.HideAsync()">
            Close
        </button>
    </FooterTemplate>
</HxModal>

@code {
    private List<int> _availableRounds = new();
    private int _selectedRound;
    private List<UnplayedMatchViewModel>? _unplayedMatches;

    private HxGrid<UnplayedMatchViewModel>? _missedMatchesGrid;
    private HxModal? _detailModal;
    private UnplayedMatchViewModel? _selectedMatch;

    protected override async Task OnInitializedAsync()
    {
        _availableRounds = await MatchesService.GetAvailableRoundsAsync();

        if (_availableRounds.Count > 0)
        {
            _selectedRound = _availableRounds[^1]; // defaults to latest round - change if you want "current round" semantics instead
            await Refresh();
        }
    }


    private async Task ShowDetailAsync(UnplayedMatchViewModel match)
    {
        _selectedMatch = match;
        if (_detailModal is not null)
        {
            await _detailModal.ShowAsync();
        }
    }

    private async Task ProcessForfeitsAsync()
    {
        var matchesWithForfeits = _unplayedMatches!.Where(m => m.HasAnyForfeit).ToList();

        await MatchesService.ProcessForfeitsAsync(matchesWithForfeits);

        await Refresh();
    }
    
    private async Task Refresh()
    {
        if (_missedMatchesGrid != null) await _missedMatchesGrid.RefreshDataAsync(); 
    }

    private async Task<GridDataProviderResult<UnplayedMatchViewModel>> GetUnplayedMatchesData(GridDataProviderRequest<UnplayedMatchViewModel> request)
    {
        var data = await MatchesService.GetUnplayedMatchesAsync(_selectedRound, request.StartIndex, request.Count, request.CancellationToken);
        return new GridDataProviderResult<UnplayedMatchViewModel> { Data = data, TotalCount = data.Count };
    }
}
