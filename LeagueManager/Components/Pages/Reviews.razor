@page "/reviews"
@using LeagueManager.Extensions
@using LeagueManager.Services
@using LeagueManager.ViewModel
@inject MainService MainService
@inject ReviewService ReviewService
@rendermode InteractiveServer

<PageTitle>Reviews</PageTitle>

@* Global actions: not selection-dependent *@
<div class="d-flex gap-2 mb-3">
    <button class="btn btn-outline-primary" @onclick="GenerateReviews">Generate Reviews</button>
    <button class="btn btn-outline-primary" @onclick="LinkReviewMatches">Link Review Matches</button>
    <button class="btn btn-outline-secondary" @onclick="RefreshCurrentGrid">↻ Refresh</button>
</div>

@* Common selection actions: operate on whichever tab is active *@
<div class="card mb-3">
    <div class="card-header fw-semibold">Selection Actions</div>
    <div class="card-body d-flex gap-2 flex-wrap py-2">
        <button class="btn btn-secondary" @onclick="SetDuplicate">Set Duplicate</button>
        <button class="btn btn-secondary" @onclick="CancelReview">Cancel</button>
        <button class="btn btn-warning" @onclick="UnlinkMatch">Unlink Match</button>
        <button class="btn btn-danger" @onclick="DeleteReviews">Delete</button>
    </div>
</div>

<HxTabPanel @bind-ActiveTabId="_activeTab" InitialActiveTabId="scheduling">

    <HxTab Id="overview" Title="Overview">
        <Content>
            <HxGrid @ref="_overviewGrid" TItem="ReviewViewModel" DataProvider="GetOverviewGridData"
                    @bind-SelectedDataItems="_selectedOverviewReviews"
                    SelectedDataItem="_selectedOverviewReview"
                    SelectedDataItemChanged="HandleSelectedOverviewReviewChanged"
                    MultiSelectionEnabled="true" PageSize="300" Responsive="true">
                <Columns>
                    <HxGridColumn HeaderText="Season" ItemTextSelector="rev => rev.SeasonName"/>
                    <HxGridColumn HeaderText="Round">
                        <ItemTemplate Context="review">
                            @if (review == _selectedOverviewReview)
                            {
                                <InputNumber @bind-Value="review.Round"/>
                            }
                            else
                            {
                                @review.Round
                            }
                        </ItemTemplate>
                    </HxGridColumn>
                    <HxGridColumn HeaderText="Black" ItemTextSelector="rev => rev.BlackPlayerName + ' ' + rev.BlackPlayerRank"/>
                    <HxGridColumn HeaderText="White" ItemTextSelector="rev => rev.WhitePlayerName + ' ' + rev.WhitePlayerRank"/>
                    <HxGridColumn HeaderText="Teacher" ItemTextSelector="rev => rev.TeacherName"/>
                    <HxGridColumn HeaderText="Owner" ItemTextSelector="rev => rev.OwnerName"/>
                    <HxGridColumn HeaderText="Owner TZ" ItemTextSelector="rev => rev.OwnerTimezone"/>
                    <HxGridColumn HeaderText="Played">
                        <ItemTemplate Context="rev">
                            <HxCheckbox @bind-Value="rev.IsPlayed" Enabled="false"/>
                        </ItemTemplate>
                    </HxGridColumn>
                </Columns>
            </HxGrid>
        </Content>
    </HxTab>

    <HxTab Id="scheduling" Title="Scheduling">
        <Content>
            <div class="card my-2">
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-auto">
                            <label class="form-label">Teacher</label>
                            <div class="d-flex gap-2">
                                <InputSelect @bind-Value="_selectedTeacherId" class="form-select">
                                    @foreach (var opt in _teacherList)
                                    {
                                        <option value="@opt.Id">@opt.Name</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                        <div class="col-auto">
                            <label class="form-label">Event Date</label>
                            <div class="d-flex gap-2">
                                <DateTimeInput TValue="DateTime?" @bind-Value="_reviewEventDate"/>
                                <button class="btn btn-primary" @onclick="SendReviewNotice">Send Notice</button>
                                <button class="btn btn-outline-primary" @onclick="MoveToAllocated">Move to Allocated</button>
                            </div>
                        </div>
                        <div class="col-auto align-self-center">
                            <HxCheckbox @bind-Value="_schedulingIncludeNoMatch"
                                        @bind-Value:after="RefreshScheduleGrid"
                                        Text="Include no Match"/>
                        </div>
                    </div>
                </div>
            </div>
            <HxGrid @ref="_schedulingGrid" TItem="ReviewViewModel" DataProvider="GetSchedulingGridData"
                    @bind-SelectedDataItems="_selectedSchedulingReviews"
                    MultiSelectionEnabled="true" PageSize="20" Responsive="true">
                <Columns>
                    <HxGridColumn HeaderText="Round" ItemTextSelector="rev => rev.Round.ToString()"/>
                    <HxGridColumn HeaderText="Black" ItemTextSelector="rev => rev.BlackPlayerName + ' ' + rev.BlackPlayerRank"/>
                    <HxGridColumn HeaderText="White" ItemTextSelector="rev => rev.WhitePlayerName + ' ' + rev.WhitePlayerRank"/>
                    <HxGridColumn HeaderText="Teacher" ItemTextSelector="rev => rev.TeacherName"/>
                    <HxGridColumn HeaderText="Owner" ItemTextSelector="rev => rev.OwnerName"/>
                    <HxGridColumn HeaderText="Owner TZ" ItemTextSelector="rev => rev.OwnerTimezone"/>
                    <HxGridColumn HeaderText="Played">
                        <ItemTemplate Context="rev">
                            <HxCheckbox @bind-Value="rev.IsPlayed" Enabled="false"/>
                        </ItemTemplate>
                    </HxGridColumn>
                </Columns>
            </HxGrid>
        </Content>
    </HxTab>

    <HxTab Id="posting">
        <TitleTemplate>Posting</TitleTemplate>
        <Content>
            <div class="d-flex gap-2 my-2">
                <button class="btn btn-primary" @onclick="PostReviews">Post Reviews</button>
                <button class="btn btn-outline-primary" @onclick="SaveChanges">Save Video URL</button>
                <button class="btn btn-outline-primary" @onclick="Deallocate">Deallocate</button>
            </div>
            <HxGrid @ref="_postingGrid" TItem="ReviewViewModel" DataProvider="GetPostingGridData"
                    SelectedDataItem="_selectedPostingReview"
                    @bind-SelectedDataItems="_selectedPostingReviews"
                    SelectedDataItemChanged="HandleSelectedPostingReviewChanged"
                    MultiSelectionEnabled="true" PageSize="20" Responsive="true">
                <Columns>
                    <HxGridColumn HeaderText="Black" ItemTextSelector="rev => rev.BlackPlayerName + ' ' + rev.BlackPlayerRank"/>
                    <HxGridColumn HeaderText="White" ItemTextSelector="rev => rev.WhitePlayerName + ' ' + rev.WhitePlayerRank"/>
                    <HxGridColumn HeaderText="Teacher" ItemTextSelector="rev => rev.TeacherName"/>
                    <HxGridColumn HeaderText="Owner" ItemTextSelector="rev => rev.OwnerHandle"/>
                    <HxGridColumn HeaderText="Link" ItemTextSelector="rev => rev.MatchUrl"/>
                    <HxGridColumn HeaderText="Video URL">
                        <ItemTemplate Context="review">
                            @if (review == _selectedPostingReview)
                            {
                                <InputText @bind-Value="review.ReviewUrl"
                                           @onkeydown="HandleSelectedPostingReviewKeyDown"/>
                            }
                            else
                            {
                                @review.ReviewUrl
                            }
                        </ItemTemplate>
                    </HxGridColumn>
                    <HxGridColumn HeaderText="Match String" ItemTextSelector="rev => rev.BuildLongMatchTitle()"/>
                </Columns>
            </HxGrid>
        </Content>
    </HxTab>

    <HxTab Id="missed" Title="Missed">
        <Content>
            <HxGrid @ref="_missedGrid" TItem="ReviewViewModel" DataProvider="GetMissedGridData"
                    @bind-SelectedDataItems="_selectedMissedReviews"
                    MultiSelectionEnabled="true" PageSize="20" Responsive="true">
                <Columns>
                    <HxGridColumn HeaderText="Black" ItemTextSelector="rev => rev.BlackPlayerName + ' ' + rev.BlackPlayerRank"/>
                    <HxGridColumn HeaderText="White" ItemTextSelector="rev => rev.WhitePlayerName + ' ' + rev.WhitePlayerRank"/>
                    <HxGridColumn HeaderText="Teacher" ItemTextSelector="rev => rev.TeacherName"/>
                    <HxGridColumn HeaderText="Owner" ItemTextSelector="rev => rev.OwnerName"/>
                    <HxGridColumn HeaderText="Owner TZ" ItemTextSelector="rev => rev.OwnerTimezone"/>
                    <HxGridColumn HeaderText="Played">
                        <ItemTemplate Context="rev">
                            <HxCheckbox @bind-Value="rev.IsPlayed" Enabled="false"/>
                        </ItemTemplate>
                    </HxGridColumn>
                </Columns>
            </HxGrid>
        </Content>
    </HxTab>

</HxTabPanel>

@code {
    private bool _schedulingIncludeNoMatch;
    private HxGrid<ReviewViewModel>? _schedulingGrid, _postingGrid, _missedGrid, _overviewGrid;
    private HashSet<ReviewViewModel>? _selectedSchedulingReviews, _selectedMissedReviews, _selectedOverviewReviews, _selectedPostingReviews;
    private ReviewViewModel? _selectedPostingReview, _selectedOverviewReview;
    private string _activeTab = string.Empty;
    private DateTime? _reviewEventDate;
    private int _selectedTeacherId;
    private List<TeacherViewModel> _teacherList = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _teacherList = await MainService.GetTeachers();
    }

    // -------------------------------------------------------------------------
    // Selection helpers
    // -------------------------------------------------------------------------

    private IEnumerable<ReviewViewModel>? GetCurrentTabSelectedList() => _activeTab switch
    {
        "overview"   => _selectedOverviewReviews,
        "scheduling" => _selectedSchedulingReviews,
        "posting"    => _selectedPostingReviews,
        "missed"     => _selectedMissedReviews,
        _            => Enumerable.Empty<ReviewViewModel>()
    };

    private void RefreshCurrentGrid()
    {
        switch (_activeTab)
        {
            case "overview":   RefreshOverviewGrid();  break;
            case "scheduling": RefreshScheduleGrid();  break;
            case "posting":    RefreshPostingGrid();   break;
            case "missed":     RefreshMissedGrid();    break;
        }
    }

    // -------------------------------------------------------------------------
    // Row-selection handlers (save on deselect)
    // -------------------------------------------------------------------------

    private async Task HandleSelectedOverviewReviewChanged(ReviewViewModel newItem)
    {
        if (_selectedOverviewReview != null)
            await MainService.SaveReviewChanges(new List<ReviewViewModel> { _selectedOverviewReview });
        _selectedOverviewReview = newItem;
    }

    private async Task HandleSelectedPostingReviewChanged(ReviewViewModel newItem)
    {
        if (_selectedPostingReview != null)
            await MainService.SaveReviewChanges(new List<ReviewViewModel> { _selectedPostingReview });
        _selectedPostingReview = newItem;
    }

    // -------------------------------------------------------------------------
    // Common selection actions — all use GetCurrentTabSelectedList()
    // -------------------------------------------------------------------------

    private async void SetDuplicate()
    {
        var selected = GetCurrentTabSelectedList();
        if (selected?.Any() != true) return;
        await MainService.SetCanceledReview(selected);
        RefreshCurrentGrid();
    }

    private async void CancelReview()
    {
        var selected = GetCurrentTabSelectedList();
        if (selected?.Any() != true) return;
        await ReviewService.SetDuplicateReview(selected);
        RefreshCurrentGrid();
    }

    private async void UnlinkMatch()
    {
        var selected = GetCurrentTabSelectedList()?.ToList();
        if (selected is not { Count: > 0 }) return;
        await MainService.UnlinkMatchFromReviews(selected, true);
        RefreshCurrentGrid();
    }

    private async void DeleteReviews()
    {
            var selected = GetCurrentTabSelectedList()?.ToList();
            if (selected is not { Count: > 0 }) return;
            await MainService.DeleteReviews(selected);
            RefreshCurrentGrid();
    }

    // -------------------------------------------------------------------------
    // Global actions
    // -------------------------------------------------------------------------

    private async void GenerateReviews()
    {
        await ReviewService.BuildReviews(); 
    }

    private async void LinkReviewMatches()
    {
        await MainService.LinkReviewMatches(); 
    }

    // -------------------------------------------------------------------------
    // Scheduling tab actions
    // -------------------------------------------------------------------------

    private async void SendReviewNotice()
    {
        if (_selectedSchedulingReviews is not { Count: > 0 }) return;
        await MainService.ScheduleReviews(_selectedSchedulingReviews, _reviewEventDate.GetValueOrDefault(), _selectedTeacherId);
        RefreshScheduleGrid();
    }

    private async void MoveToAllocated()
    {
        if (_selectedSchedulingReviews is not { Count: > 0 }) return;
        await ReviewService.MoveToAllocated(_selectedSchedulingReviews.Select(rv => rv.ToReviewDto()).ToArray());
        RefreshScheduleGrid();
    }

    // -------------------------------------------------------------------------
    // Posting tab actions
    // -------------------------------------------------------------------------

    private async void Deallocate()
    {
        if (_selectedPostingReviews is not { Count: > 0 }) return;
        await ReviewService.Deallocate(_selectedPostingReviews);
        RefreshPostingGrid();
    }
    
    private async void PostReviews()
    {
         await MainService.PostReviews(); 
         RefreshPostingGrid();
    }

    private async Task SaveChanges()
    {
        if (_selectedPostingReview == null) return;
        await MainService.SaveReviewChanges(new List<ReviewViewModel> { _selectedPostingReview });
    }

    private async void HandleSelectedPostingReviewKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveChanges();
    }

    // -------------------------------------------------------------------------
    // Grid data providers
    // -------------------------------------------------------------------------

    private async Task<GridDataProviderResult<ReviewViewModel>> GetOverviewGridData(GridDataProviderRequest<ReviewViewModel> request)
    {
        var data = await ReviewService.GetOverviewReviews(request.StartIndex, request.Count, request.CancellationToken);
        return new GridDataProviderResult<ReviewViewModel> { Data = data, TotalCount = data.Count };
    }

    private async Task<GridDataProviderResult<ReviewViewModel>> GetSchedulingGridData(GridDataProviderRequest<ReviewViewModel> request)
    {
        var data = await ReviewService.GetReviewsToSchedule(request.StartIndex, request.Count, request.CancellationToken, _schedulingIncludeNoMatch);
        return new GridDataProviderResult<ReviewViewModel> { Data = data, TotalCount = data.Count };
    }

    private async Task<GridDataProviderResult<ReviewViewModel>> GetPostingGridData(GridDataProviderRequest<ReviewViewModel> request)
    {
        var data = await ReviewService.GetReviewsToPost(request.StartIndex, request.Count, request.CancellationToken);
        return new GridDataProviderResult<ReviewViewModel> { Data = data, TotalCount = data.Count };
    }

    private async Task<GridDataProviderResult<ReviewViewModel>> GetMissedGridData(GridDataProviderRequest<ReviewViewModel> request)
    {
        var data = await MainService.GetMissedReviews(request.StartIndex, request.Count, request.CancellationToken);
        return new GridDataProviderResult<ReviewViewModel> { Data = data, TotalCount = data.Count };
    }

    // -------------------------------------------------------------------------
    // Grid refresh helpers
    // -------------------------------------------------------------------------

    private async void RefreshOverviewGrid()
    {
        if (_overviewGrid != null) await _overviewGrid.RefreshDataAsync(); 
    }

    private async void RefreshScheduleGrid()
    {
        if (_schedulingGrid != null) await _schedulingGrid.RefreshDataAsync();
    }

    private async void RefreshPostingGrid()
    {
        if (_postingGrid != null) await _postingGrid.RefreshDataAsync();
    }

    private async void RefreshMissedGrid()
    {
        if (_missedGrid != null) await _missedGrid.RefreshDataAsync();
    }
}
