@using LeagueManager.Services
@using LeagueManager.ViewModel
@using Shared.Enum

@using LeagueManager.ViewModel
@using Shared.Enum

@if (IsOpen && Player != null)
{
    <div class="card ms-3 overflow-auto" style="min-width: 360px; max-width: 400px; height: 100%;">
        <div class="card-body d-flex flex-column gap-4 p-3">

            @* {{!-- Header --}} *@
            <div class="d-flex justify-content-between align-items-start">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary fw-semibold d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;font-size:14px;flex-shrink:0">
                        @Initials
                    </div>
                    <div>
                        <div class="fw-semibold">@Player.FirstName @Player.LastName</div>
                        <div class="d-flex align-items-center gap-2 mt-1">
                            <small class="text-muted">Player #@Player.Id</small>
                            <span class="badge bg-secondary">@Player.Rank.GetDisplayName()</span>
                        </div>
                    </div>
                </div>
                <button class="btn btn-sm btn-outline-secondary" @onclick="OnClose">✕</button>
            </div>

            @* {{!-- Contact --}} *@
            <div>
                <div class="text-muted small fw-semibold text-uppercase mb-2">Contact</div>
                <div class="row g-2">
                    <div class="col-12">
                        <div class="small text-muted">Email</div>
                        <div class="small">@(Player.EmailAddress ?? "—")</div>
                    </div>
                    <div class="col-6">
                        <div class="small text-muted">Timezone</div>
                        <div class="small">@(Player.TimeZone ?? "—")</div>
                    </div>
                    <div class="col-6">
                        <div class="small text-muted">Leago ID</div>
                        <div class="small font-monospace">@(Player.LeagoMemberId ?? "—")</div>
                    </div>
                </div>
            </div>

            @* {{!-- Discord --}} *@
            <div>
                <div class="text-muted small fw-semibold text-uppercase mb-2">Discord</div>
                <div class="row g-2">
                    <div class="col-6">
                        <label class="small text-muted mb-1">Handle</label>
                        <input type="text"
                               class="form-control form-control-sm @(_editHandle != (Player.DiscordHandle ?? "") ? "border-primary" : "")"
                               @bind="_editHandle" placeholder="username"/>
                    </div>
                    <div class="col-6">
                        <label class="small text-muted mb-1">Discord ID</label>
                        <input type="text"
                               class="form-control form-control-sm @(_editDiscordId != (Player.DiscordId?.ToString() ?? "") ? "border-primary" : "")"
                               @bind="_editDiscordId" placeholder="snowflake ID"/>
                    </div>
                </div>
            </div>

            @* {{!-- Platforms --}} *@
            <div>
                <div class="text-muted small fw-semibold text-uppercase mb-2">Platforms</div>
                <div class="row g-2">
                    <div class="col-6">
                        <div class="small text-muted">OGS handle</div>
                        <div class="small">@(Player.OgsHandle ?? "—")</div>
                    </div>
                    <div class="col-6">
                        <div class="small text-muted">GoMagic user ID</div>
                        <div class="small font-monospace">@(Player.GoMagicUserId?.ToString() ?? "—")</div>
                    </div>
                </div>
            </div>

            @* {{!-- Seasons --}} *@
            <div class="flex-grow-1">
                <div class="text-muted small fw-semibold text-uppercase mb-2">Seasons</div>
                @if (_seasonsLoading)
                {
                    <div class="small text-muted">Loading…</div>
                }
                else if (_editSeasons.Count == 0)
                {
                    <div class="small text-muted">No seasons.</div>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                        <tr>
                            <th class="fw-normal text-muted small">Season</th>
                            <th class="fw-normal text-muted small">Tier</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var ps in _editSeasons)
                        {
                            <tr>
                                <td class="align-middle small">@ps.SeasonTitle</td>
                                <td class="align-middle">
                                    <select class="form-select form-select-sm @(ps.PlayerParticipationTier != OriginalTier(ps.SeasonId) ? "border-primary" : "")"
                                            value="@ps.PlayerParticipationTier"
                                            @onchange="e => HandleTierChange(ps, e)">
                                        @foreach (var tier in Enum.GetValues<PlayerParticipationTier>())
                                        {
                                            <option value="@tier">@tier</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>

            @* {{!-- Actions --}} *@
            <div class="d-flex gap-2 pt-2 border-top">
                <button class="btn btn-primary btn-sm" disabled="@(!IsDirty)" @onclick="Save">Save changes</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="OnClose">Cancel</button>
            </div>

        </div>
    </div>
}

@code {
    [Parameter] public PlayerViewModel? Player { get; set; }
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<PlayerViewModel> OnSave { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    [Inject] public MainService MainService { get; set; } = default!;

    private string _editHandle = "";
    private string _editDiscordId = "";
    private List<PlayerSeasonViewModel> _editSeasons = new();
    private Dictionary<int, PlayerParticipationTier> _originalTiers = new();
    private bool _seasonsLoading = false;

    private string Initials => Player is null
        ? ""
        : $"{Player.FirstName?[0]}{Player.LastName?[0]}".ToUpperInvariant();

    private bool IsDirty =>
        _editHandle != (Player?.DiscordHandle ?? "") ||
        _editDiscordId != (Player?.DiscordId?.ToString() ?? "") ||
        _editSeasons.Any(ps => ps.PlayerParticipationTier != OriginalTier(ps.SeasonId));

    private PlayerParticipationTier OriginalTier(int seasonId) =>
        _originalTiers.GetValueOrDefault(seasonId);

    protected override async Task OnParametersSetAsync()
    {
        if (Player is null) return;

        _editHandle = Player.DiscordHandle ?? "";
        _editDiscordId = Player.DiscordId?.ToString() ?? "";

        // reload seasons only when the selected player actually changes
        if (Player.Id != _lastLoadedPlayerId)
        {
            _lastLoadedPlayerId = Player.Id;
            _editSeasons = new();
            _originalTiers = new();
            _seasonsLoading = true;

            var seasons = await MainService.GetPlayerSeasons(Player.Id!.Value);

            _editSeasons = seasons.Select(ps => new PlayerSeasonViewModel
            {
                PlayerId = ps.PlayerId,
                SeasonId = ps.SeasonId,
                SeasonTitle = ps.SeasonTitle,
                PlayerParticipationTier = ps.PlayerParticipationTier
            }).ToList();
            _originalTiers = seasons.ToDictionary(ps => ps.SeasonId, ps => ps.PlayerParticipationTier);
            _seasonsLoading = false;
        }
    }

    private int? _lastLoadedPlayerId;

    private void HandleTierChange(PlayerSeasonViewModel ps, ChangeEventArgs e)
    {
        if (Enum.TryParse<PlayerParticipationTier>(e.Value?.ToString(), out var tier))
            ps.PlayerParticipationTier = tier;
    }

    private async Task Save()
    {
        if (Player is null) return;
        var updated = new PlayerViewModel
        {
            Id = Player.Id,
            FirstName = Player.FirstName,
            LastName = Player.LastName,
            EmailAddress = Player.EmailAddress,
            OgsHandle = Player.OgsHandle,
            LeagoMemberId = Player.LeagoMemberId,
            Rank = Player.Rank,
            LeagoKey = Player.LeagoKey,
            GoMagicUserId = Player.GoMagicUserId,
            TimeZone = Player.TimeZone,
            DiscordHandle = string.IsNullOrWhiteSpace(_editHandle) ? null : _editHandle,
            DiscordId = ulong.TryParse(_editDiscordId, out var id) ? id : null,
        };
        await OnSave.InvokeAsync(updated);
    }
}